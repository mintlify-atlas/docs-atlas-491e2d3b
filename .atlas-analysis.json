  "publicApiSurface": [
    "login_microsoft() - Authenticate with Microsoft account",
    "login_offline() - Create offline account",
    "client_account_authenticate() - Authenticate LiquidBounce account",
    "run_client() - Launch Minecraft with LiquidBounce",
    "request_branches() - Get available build branches",
    "request_builds() - Get builds for a branch",
    "request_mods() - Fetch available mods",
    "install_custom_mod() - Install custom mod file",
    "delete_custom_mod() - Remove custom mod",
    "terminate() - Stop running game instance"
  ]
